{
  "name": "zawyafi-square-testing-cafe-integration",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Square sandbox backend for cafe API and webhooks integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:catalog": "node scripts/setup-square-catalog.mjs",
    "seed:square": "node scripts/seed-square-cafe.mjs",
    "test:cafe-flow": "node scripts/test-cafe-flow.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
